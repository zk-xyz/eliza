{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "sourceMap": true,
        "inlineSources": true,
        "sourceRoot": "/",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true
    },
    "include": ["src/**/*"],
    "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}